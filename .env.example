# Google reCAPTCHA v3
# Get these from https://www.google.com/recaptcha/admin
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_site_key_here
RECAPTCHA_SECRET_KEY=your_secret_key_here

# Gmail API (contact form notification email)
# OAuth app credentials + a refresh token with the gmail.send scope.
# The contact route mints a short-lived access token from these and emails
# brian.g.flett@gmail.com. Shared with Klaus's Google OAuth app.
GOOGLE_OAUTH_CLIENT_ID=your_client_id_here
GOOGLE_OAUTH_CLIENT_SECRET=your_client_secret_here
GMAIL_OAUTH_REFRESH_TOKEN=your_refresh_token_here
